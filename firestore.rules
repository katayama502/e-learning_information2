rules_version = '2';

// ============================================================
//  Firestore セキュリティルール
//  Firebase コンソール → Firestore Database → ルール に貼り付ける。
//  管理者判定はカスタムクレーム admin==true を使用
//  （シードスクリプト / ユーザー作成APIが付与する）。
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ユーザー情報（作成・変更・削除は基本的にAdmin SDK経由）
    match /users/{uid} {
      allow read:  if isAdmin() || isOwner(uid);
      allow write: if isAdmin();
    }

    // 学習進捗（本人のみ読み書き、管理者は閲覧可）
    match /progress/{uid} {
      allow read:  if isAdmin() || isOwner(uid);
      allow write: if isOwner(uid);
    }

    // カリキュラム（ログインユーザーは閲覧、管理者のみ編集）
    match /units/{id} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }
    match /materials/{id} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
